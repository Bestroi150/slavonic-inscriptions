            <div type="edition" xml:space="preserve" xml:lang="chu">
                <ab>
                    <lb n="1"/> <w lemmaRef="https://histdict.uni-sofia.bg/dictionary/show/d_01716">вѣнаа</w> <w lemmaRef="https://histdict.uni-sofia.bg/dictionary/show/d_06296">пам<supplied reason = "lost">ѧт</supplied></w>
