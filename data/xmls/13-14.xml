                    <lb n="4"/> <roleName ref="titles.xml#n005"><expan><abbr>патр̄а</abbr><ex>р</ex><abbr>х</abbr><ex>ъ</ex></expan></roleName>
                </ab>
            </div>
            <div type="apparatus">
                <listApp>
                    <head xml:lang="bg">Букви в лигатура:</head>
                    <head xml:lang="en">Letters in ligatures:</head>
