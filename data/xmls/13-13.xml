            <div type="edition" xml:space="preserve" xml:lang="chu">
                <ab>
                    <lb n="1"/> <g type="cross"/> <w lemmaRef="https://histdict.uni-sofia.bg/dictionary/show/d_09490/">се</w> <w lemmaRef="https://histdict.uni-sofia.bg/dictionary/show/d_10565/">хра  
                    <lb n="2" break="no"/>мь</w> <w lemmaRef="https://histdict.uni-sofia.bg/dictionary/show/d_05506/">о</w> <persName ref="relig.xml#ArchMich"><expan><abbr>арх</abbr><ex>стратга</ex></expan>Міхалъꙗ</persName> 
                </ab>
            </div>
            <div type="apparatus">
