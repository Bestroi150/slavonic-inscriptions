            <div type="edition" xml:space="preserve" xml:lang="chu">
                <ab>
                    <lb n="1"/> <g type="cross"/> <w lemmaRef="https://histdict.uni-sofia.bg/dictionary/show/d_00068/">азъ</w> <persName ref="names.xml#n016">хнатъ</persName> <w lemma="граматкъ">кра  
