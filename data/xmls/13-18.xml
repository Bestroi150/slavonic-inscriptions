                    <lb n="2"/> <w lemmaRef="https://histdict.uni-sofia.bg/dictionary/show/d_07052">по</w> <persName ref="names.xml#n052">мхе</persName> <orig>м</orig> <gap reason="lost" extent="unknown" unit="character"/>
                </ab>
            </div>
